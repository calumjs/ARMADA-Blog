---
// CarvePlank — "carve into plank" quote sharing for blog posts (#193).
//
// Selecting ≥ 10 characters inside the post body (the `.prose` block rendered
// by BlogBody) surfaces a small floating "Carve into plank 🪓" button near the
// selection. Clicking it copies a plain-text quote to the clipboard via
// navigator.clipboard.writeText only — the quoted text, an em-dash attribution
// with the post title, and the canonical post URL — then shows a brief
// "Carved! ⚓" confirmation. No canvas, no images, no network, no deps.
//
// Rendered ONLY by the BlogPost layout, so it exists on post body pages alone;
// the delegated script no-ops when the markup is absent after a ClientRouter
// swap to another page. The listeners are bound once to document/window and
// guarded by a window flag so they survive Astro ClientRouter swaps and Tina
// re-renders (same convention as KrakenEasterEgg.astro / VoyageProgress.astro).
//
// Behaviour notes:
// - Evaluated on pointerup/keyup (mouse AND keyboard selections, e.g.
//   Shift+Arrow), never during the drag — it NEVER intercepts or alters normal
//   selection behaviour on the page itself.
// - Dismissed on scroll, click-away, Escape, selection collapse, and before
//   every route swap; works again after astro:after-swap.
// - Only mousedown ON THE BUTTON is prevented (so the click doesn't collapse
//   the selection it's about to carve) — page-level events are untouched.

interface Props {
	title: string;
	url: string;
}

const { title, url } = Astro.props;
---

<div id="carve-plank" data-carve-title={title} data-carve-url={url} hidden>
	<button type="button" id="carve-plank-btn" class="carve-btn">
		<span class="carve-label">Carve into plank 🪓</span>
		<span class="carve-done" hidden>Carved! ⚓</span>
	</button>
	<!-- Announces the confirmation to screen readers without moving focus. -->
	<span id="carve-plank-status" class="sr-only" role="status" aria-live="polite"></span>
</div>

<style>
	#carve-plank {
		position: fixed;
		top: 0;
		left: 0;
		/* Above the fixed header (z-20), voyage bar (z-30) and bottle (40);
		   the Kraken overlay (9999) still wins. */
		z-index: 60;
	}

	#carve-plank[hidden] {
		display: none;
	}

	.carve-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.4rem 0.8rem;
		border-radius: var(--radius-md);
		/* Wooden plank: warm timber browns that hold up across all themes. */
		border: 1px solid oklch(0.42 0.07 60 / 0.85);
		background: linear-gradient(
			oklch(0.55 0.085 65),
			oklch(0.47 0.08 58)
		);
		color: oklch(0.97 0.02 85);
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		white-space: nowrap;
		cursor: pointer;
		user-select: none;
		-webkit-user-select: none;
		box-shadow:
			inset 0 1px 0 oklch(0.72 0.08 70 / 0.5),
			0 3px 10px oklch(0.15 0.03 60 / 0.45);
		transition: transform 120ms ease, box-shadow 120ms ease;
	}

	.carve-btn:hover {
		transform: translateY(-1px);
		box-shadow:
			inset 0 1px 0 oklch(0.72 0.08 70 / 0.5),
			0 5px 14px oklch(0.15 0.03 60 / 0.5);
	}

	.carve-btn:focus-visible {
		outline: none;
		box-shadow:
			inset 0 1px 0 oklch(0.72 0.08 70 / 0.5),
			0 0 0 3px oklch(0.55 0.11 78 / 0.6);
	}

	.carve-btn.is-carved {
		background: linear-gradient(oklch(0.5 0.09 160), oklch(0.42 0.08 165));
		border-color: oklch(0.38 0.07 165 / 0.85);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.carve-btn {
			transition: none;
		}
		.carve-btn:hover {
			transform: none;
		}
	}
</style>

<script is:inline>
	// Bind once to document/window so the plank survives Astro ClientRouter
	// swaps and Tina re-renders (same convention as VoyageProgress.astro).
	// Every callback re-queries the DOM and no-ops on non-post pages.
	if (!window.__carvePlankBound) {
		window.__carvePlankBound = true;

		var MIN_CHARS = 10;
		var carveText = '';
		var carveTimer = 0;

		function carveRoot() {
			return document.getElementById('carve-plank');
		}

		function carveHide() {
			var root = carveRoot();
			if (!root) return;
			if (carveTimer) {
				clearTimeout(carveTimer);
				carveTimer = 0;
			}
			root.hidden = true;
			var btn = document.getElementById('carve-plank-btn');
			if (btn) {
				btn.classList.remove('is-carved');
				var label = btn.querySelector('.carve-label');
				var done = btn.querySelector('.carve-done');
				if (label) label.hidden = false;
				if (done) done.hidden = true;
			}
			carveText = '';
		}

		// True when the node lives inside the post body (`.prose`, as rendered
		// by BlogBody and also used by VoyageProgress to find the article).
		function carveInProse(node) {
			if (!node) return false;
			var el = node.nodeType === 1 ? node : node.parentElement;
			return !!(el && el.closest && el.closest('.prose'));
		}

		// Show the button near the current selection, or hide when it no
		// longer qualifies. Runs after the gesture completes (pointerup/keyup),
		// never during it, so normal selection behaviour is untouched.
		function carveEvaluate() {
			var root = carveRoot();
			if (!root) return; // not a blog post page

			var sel = window.getSelection ? window.getSelection() : null;
			if (!sel || sel.isCollapsed || sel.rangeCount === 0) {
				carveHide();
				return;
			}

			var text = sel.toString().replace(/\s+/g, ' ').trim();
			if (text.length < MIN_CHARS) {
				carveHide();
				return;
			}

			var range = sel.getRangeAt(0);
			if (
				!carveInProse(range.commonAncestorContainer) ||
				!carveInProse(sel.anchorNode) ||
				!carveInProse(sel.focusNode)
			) {
				carveHide();
				return;
			}

			var rect = range.getBoundingClientRect();
			if (!rect || (rect.width === 0 && rect.height === 0)) {
				carveHide();
				return;
			}

			carveText = text;

			// Reset any lingering "Carved!" state, then position. The element
			// must be visible to measure, so unhide before measuring.
			var btn = document.getElementById('carve-plank-btn');
			if (btn) {
				btn.classList.remove('is-carved');
				var label = btn.querySelector('.carve-label');
				var done = btn.querySelector('.carve-done');
				if (label) label.hidden = false;
				if (done) done.hidden = true;
			}
			if (carveTimer) {
				clearTimeout(carveTimer);
				carveTimer = 0;
			}
			root.hidden = false;

			var w = root.offsetWidth;
			var h = root.offsetHeight;
			var gap = 10;
			var vw = window.innerWidth;

			var left = rect.left + rect.width / 2 - w / 2;
			left = Math.max(8, Math.min(left, vw - w - 8));

			// Prefer floating above the selection; drop below when there's no
			// headroom (keeps clear of the fixed header + voyage bar).
			var top = rect.top - h - gap;
			if (top < 72) top = rect.bottom + gap;

			root.style.left = left + 'px';
			root.style.top = top + 'px';
		}

		function carveCopy() {
			var root = carveRoot();
			if (!root || !carveText) return;

			var title = root.getAttribute('data-carve-title') || document.title;
			var url = root.getAttribute('data-carve-url') || location.href;
			var payload = '“' + carveText + '”\n\n— ' + title + '\n' + url;

			if (!(navigator.clipboard && navigator.clipboard.writeText)) {
				carveHide();
				return;
			}

			navigator.clipboard.writeText(payload).then(
				function () {
					var btn = document.getElementById('carve-plank-btn');
					var status = document.getElementById('carve-plank-status');
					if (btn) {
						btn.classList.add('is-carved');
						var label = btn.querySelector('.carve-label');
						var done = btn.querySelector('.carve-done');
						if (label) label.hidden = true;
						if (done) done.hidden = false;
					}
					if (status) status.textContent = 'Quote carved to clipboard';
					if (carveTimer) clearTimeout(carveTimer);
					carveTimer = window.setTimeout(function () {
						carveTimer = 0;
						carveHide();
						if (status) status.textContent = '';
					}, 1400);
				},
				function () {
					// Clipboard permission refused — just retire quietly.
					carveHide();
				}
			);
		}

		// Evaluate once the selection gesture ends (mouse or keyboard). Deferred
		// a tick so the browser has committed the final selection first.
		document.addEventListener('pointerup', function (e) {
			if (e.target && e.target.closest && e.target.closest('#carve-plank')) return;
			window.setTimeout(carveEvaluate, 0);
		});
		document.addEventListener('keyup', function (e) {
			// Keyboard selections (Shift+Arrows, Ctrl/Cmd+A, Home/End variants).
			if (e.key === 'Shift' || e.shiftKey || e.key === 'a' || e.key === 'A') {
				window.setTimeout(carveEvaluate, 0);
			} else if (e.key === 'Escape') {
				carveHide();
			}
		});

		// Hide as soon as the selection itself collapses (e.g. plain click).
		document.addEventListener('selectionchange', function () {
			var root = carveRoot();
			if (!root || root.hidden) return;
			var sel = window.getSelection ? window.getSelection() : null;
			if (!sel || sel.isCollapsed) carveHide();
		});

		// Click-away / press-away dismisses; pressing the button itself keeps
		// the selection alive (mousedown would otherwise collapse it before the
		// click event fires — this preventDefault is scoped to the button only).
		document.addEventListener('pointerdown', function (e) {
			var t = e.target;
			if (t && t.closest && t.closest('#carve-plank')) {
				e.preventDefault();
				return;
			}
			var root = carveRoot();
			if (root && !root.hidden) carveHide();
		});

		// The actual carve.
		document.addEventListener('click', function (e) {
			var t = e.target;
			if (t && t.closest && t.closest('#carve-plank-btn')) carveCopy();
		});

		// Any scroll dismisses (capture catches scrolls in nested containers).
		window.addEventListener(
			'scroll',
			function () {
				var root = carveRoot();
				if (root && !root.hidden) carveHide();
			},
			{ passive: true, capture: true }
		);
		window.addEventListener('resize', carveHide, { passive: true });

		// Start every route swap clean; the fresh page's markup (or absence of
		// it) is picked up automatically because everything re-queries the DOM.
		document.addEventListener('astro:before-swap', carveHide);
		document.addEventListener('astro:after-swap', carveHide);
	}
</script>
