---
// Gold price chart — a fully client-side island.
//
// Calls three keyless, CORS-enabled, browser-safe third-party APIs directly
// (no backend, no proxy, no secrets):
//   - current spot USD/oz  : https://api.gold-api.com/price/XAU
//   - historical USD/oz     : https://freegoldapi.com/data/latest.json  (annual)
//   - USD->AUD FX           : https://api.frankfurter.dev/v1/latest?base=USD&symbols=AUD
//
// Everything is converted to AUD (USD x FX) and optionally to AUD/gram
// (1 troy oz = 31.1034768 g). The chart is hand-rolled SVG — no charting
// dependency — so the static Astro build stays lean. The script defensively
// validates every third-party response shape before rendering, keeps the last
// good chart on a refresh failure, and never throws into the page.
---

<section
	id="gold"
	class="flex scroll-mt-24 flex-col gap-6 rounded-xl border bg-card p-5 text-card-foreground shadow-sm sm:p-6"
	data-gold-root
>
	<!-- Latest price — exposed as text (not only inside the chart) for a11y. -->
	<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
		<div class="flex flex-col gap-1">
			<h2 class="text-sm font-medium text-muted-foreground">Latest gold price</h2>
			<p class="flex items-baseline gap-2">
				<span
					id="gold-latest"
					class="font-serif text-3xl font-semibold tracking-tight tabular-nums sm:text-4xl"
					aria-live="polite"
				>—</span>
				<span id="gold-latest-unit" class="text-sm text-muted-foreground">AUD / oz</span>
			</p>
			<p class="text-xs text-muted-foreground">
				<span id="gold-updated">Loading latest price…</span>
			</p>
			<p class="text-xs text-muted-foreground/80">
				Indicative, delayed price — for information only, not investment advice.
			</p>
		</div>

		<!-- Unit toggle (oz / gram). radiogroup so it is keyboard-accessible and the
		     selected state is conveyed by aria-checked + a text label, not colour. -->
		<div
			class="flex flex-col gap-1"
			role="radiogroup"
			aria-label="Price unit"
			data-gold-units
		>
			<span class="text-xs font-medium text-muted-foreground">Unit</span>
			<div class="inline-flex rounded-md border bg-background p-0.5">
				<button
					type="button"
					role="radio"
					aria-checked="true"
					data-gold-unit="oz"
					class="rounded px-3 py-1 text-sm font-medium transition-colors aria-checked:bg-primary aria-checked:text-primary-foreground"
				>per oz</button>
				<button
					type="button"
					role="radio"
					aria-checked="false"
					data-gold-unit="g"
					class="rounded px-3 py-1 text-sm font-medium transition-colors aria-checked:bg-primary aria-checked:text-primary-foreground"
				>per gram</button>
			</div>
		</div>
	</div>

	<!-- Range controls. Each is a real <button>; the active one is marked with
	     aria-pressed (not colour alone). Ranges without free granular data are
	     disabled and explain why via title + the message region below. -->
	<div class="flex flex-col gap-2">
		<div
			class="flex flex-wrap gap-2"
			role="group"
			aria-label="Chart time range"
			data-gold-ranges
		>
			<button type="button" data-gold-range="1D" disabled aria-pressed="false"
				title="Intraday data isn't available from the free source"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1D</button>
			<button type="button" data-gold-range="1W" disabled aria-pressed="false"
				title="Weekly granularity isn't available from the free source"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1W</button>
			<button type="button" data-gold-range="1M" disabled aria-pressed="false"
				title="Monthly granularity isn't available from the free source"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1M</button>
			<button type="button" data-gold-range="6M" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>6M</button>
			<button type="button" data-gold-range="1Y" aria-pressed="true"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>1Y</button>
			<button type="button" data-gold-range="5Y" aria-pressed="false"
				class="rounded-full border bg-background px-3 py-1 text-sm font-medium transition-colors hover:enabled:text-foreground aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground disabled:cursor-not-allowed disabled:opacity-40"
			>5Y</button>
		</div>
		<p id="gold-range-note" class="min-h-4 text-xs text-muted-foreground" aria-live="polite"></p>
	</div>

	<!-- Chart region. The SVG is responsive via viewBox; a text status sits
	     above it so loading/error are conveyed without relying on the graphic. -->
	<div class="flex flex-col gap-2">
		<p id="gold-chart-status" class="text-sm text-muted-foreground" aria-live="polite">
			Loading historical prices…
		</p>
		<div
			class="relative w-full overflow-hidden rounded-md border bg-background"
			data-gold-chart-wrap
		>
			<svg
				id="gold-chart"
				viewBox="0 0 800 320"
				preserveAspectRatio="none"
				class="block h-[260px] w-full sm:h-[320px]"
				role="img"
				aria-label="Historical gold price line chart in Australian dollars"
			></svg>
			<!-- Tooltip; hidden until hover/tap, position set by the script. -->
			<div
				id="gold-tooltip"
				role="status"
				class="pointer-events-none absolute z-10 hidden -translate-x-1/2 -translate-y-full rounded-md border bg-popover px-2 py-1 text-xs text-popover-foreground shadow-md"
			></div>
		</div>
		<p class="text-xs text-muted-foreground/80">
			Historical data is annual (year-end) from a free source — adequate for
			long-range trend, not intraday detail. Latest price refreshes every 5 minutes.
		</p>
	</div>
</section>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-gold-root]');
		if (!root || root.dataset.goldBound === '1') return;
		root.dataset.goldBound = '1';

		// ---- Endpoints (keyless, CORS-safe, browser-only) --------------------
		const SPOT_URL = 'https://api.gold-api.com/price/XAU';
		const FX_URL = 'https://api.frankfurter.dev/v1/latest?base=USD&symbols=AUD';
		const HIST_URL = 'https://freegoldapi.com/data/latest.json';
		const GRAMS_PER_OZ = 31.1034768;
		const REFRESH_MS = 5 * 60 * 1000;

		// Ranges with no free granular data — disabled in the markup; listed here
		// so the friendly "unavailable" note can name them if one is reached.
		const UNAVAILABLE = { '1D': true, '1W': true, '1M': true };
		const RANGE_YEARS = { '6M': 0.5, '1Y': 1, '5Y': 5 };

		// ---- Elements --------------------------------------------------------
		const latestEl = root.querySelector('#gold-latest');
		const latestUnitEl = root.querySelector('#gold-latest-unit');
		const updatedEl = root.querySelector('#gold-updated');
		const chartEl = root.querySelector('#gold-chart');
		const chartStatusEl = root.querySelector('#gold-chart-status');
		const rangeNoteEl = root.querySelector('#gold-range-note');
		const tooltipEl = root.querySelector('#gold-tooltip');
		const chartWrap = root.querySelector('[data-gold-chart-wrap]');
		const SVGNS = 'http://www.w3.org/2000/svg';

		// ---- State -----------------------------------------------------------
		let unit = 'oz'; // 'oz' | 'g'
		let range = '1Y';
		let fxRate = null; // USD -> AUD
		let spotUsd = null; // latest spot, USD/oz
		let spotUpdatedAt = null;
		let history = []; // [{ t: epochMs, usd: usdPerOz }] sorted ascending
		let refreshTimer = null;

		// ---- Helpers ---------------------------------------------------------
		const isFiniteNum = (n) => typeof n === 'number' && isFinite(n);

		const fmtAud = (v) =>
			new Intl.NumberFormat('en-AU', {
				style: 'currency',
				currency: 'AUD',
				maximumFractionDigits: unit === 'g' ? 2 : 0,
			}).format(v);

		const toUnit = (usdPerOz) => {
			if (!isFiniteNum(usdPerOz) || !isFiniteNum(fxRate)) return null;
			const audPerOz = usdPerOz * fxRate;
			return unit === 'g' ? audPerOz / GRAMS_PER_OZ : audPerOz;
		};

		const unitLabel = () => (unit === 'g' ? 'AUD / g' : 'AUD / oz');

		async function getJson(url) {
			const res = await fetch(url, { headers: { accept: 'application/json' } });
			if (!res.ok) throw new Error(`HTTP ${res.status}`);
			return res.json();
		}

		// ---- Render: latest price (text, not only in the chart) --------------
		function renderLatest() {
			const v = toUnit(spotUsd);
			latestUnitEl.textContent = unitLabel();
			if (v == null) {
				latestEl.textContent = '—';
				return;
			}
			latestEl.textContent = fmtAud(v);
			if (spotUpdatedAt) {
				const d = new Date(spotUpdatedAt);
				const when = isNaN(d.valueOf())
					? 'just now'
					: d.toLocaleString('en-AU', { dateStyle: 'medium', timeStyle: 'short' });
				updatedEl.textContent = `Last updated ${when} · delayed`;
			} else {
				updatedEl.textContent = 'Delayed price';
			}
		}

		// ---- Render: the SVG line chart --------------------------------------
		function visiblePoints() {
			const years = RANGE_YEARS[range];
			if (!years || !history.length) return [];
			const cutoff = Date.now() - years * 365.25 * 24 * 3600 * 1000;
			let pts = history.filter((p) => p.t >= cutoff);
			// Always keep at least the two most recent points so a sparse annual
			// series still draws a line for shorter ranges.
			if (pts.length < 2 && history.length >= 2) pts = history.slice(-2);
			return pts;
		}

		function clearChart() {
			while (chartEl.firstChild) chartEl.removeChild(chartEl.firstChild);
		}

		let chartGeom = null; // for hit-testing the tooltip

		function renderChart() {
			clearChart();
			tooltipEl.classList.add('hidden');
			chartGeom = null;

			if (UNAVAILABLE[range]) {
				rangeNoteEl.textContent =
					`The ${range} view isn't available — the free historical source only provides annual data. Try 6M, 1Y or 5Y.`;
				chartStatusEl.textContent = 'Select 6M, 1Y or 5Y to view the chart.';
				return;
			}
			rangeNoteEl.textContent = '';

			const pts = visiblePoints();
			if (fxRate == null) {
				chartStatusEl.textContent = 'Waiting for the exchange rate…';
				return;
			}
			if (pts.length < 2) {
				chartStatusEl.textContent = 'Not enough historical data to draw a chart for this range.';
				return;
			}

			const W = 800, H = 320, padL = 64, padR = 16, padT = 16, padB = 28;
			const vals = pts.map((p) => toUnit(p.usd)).filter(isFiniteNum);
			if (vals.length < 2) {
				chartStatusEl.textContent = 'Not enough historical data to draw a chart for this range.';
				return;
			}
			let min = Math.min(...vals);
			let max = Math.max(...vals);
			if (min === max) { min -= 1; max += 1; }
			const pad = (max - min) * 0.08;
			min -= pad; max += pad;

			const t0 = pts[0].t, t1 = pts[pts.length - 1].t;
			const span = Math.max(1, t1 - t0);
			const x = (t) => padL + ((t - t0) / span) * (W - padL - padR);
			const y = (v) => padT + (1 - (v - min) / (max - min)) * (H - padT - padB);

			const mk = (name, attrs) => {
				const el = document.createElementNS(SVGNS, name);
				for (const k in attrs) el.setAttribute(k, attrs[k]);
				return el;
			};

			// Y gridlines + labels (text labels, so values aren't colour-only).
			const ticks = 4;
			for (let i = 0; i <= ticks; i++) {
				const v = min + ((max - min) * i) / ticks;
				const gy = y(v);
				chartEl.appendChild(mk('line', {
					x1: padL, x2: W - padR, y1: gy, y2: gy,
					stroke: 'var(--border)', 'stroke-width': '1',
				}));
				const label = mk('text', {
					x: padL - 8, y: gy + 4, 'text-anchor': 'end',
					fill: 'var(--muted-foreground)', 'font-size': '12',
				});
				label.textContent = fmtAud(v);
				chartEl.appendChild(label);
			}

			// X axis end labels. Annual granularity over long ranges, month+year
			// when the window is short enough that a bare year would be ambiguous.
			const spanDays = span / (24 * 3600 * 1000);
			const fmtAxis = (t) => {
				const d = new Date(t);
				return spanDays <= 800
					? d.toLocaleDateString('en-AU', { month: 'short', year: 'numeric' })
					: d.getFullYear().toString();
			};
			const xs = mk('text', { x: padL, y: H - 8, 'text-anchor': 'start', fill: 'var(--muted-foreground)', 'font-size': '12' });
			xs.textContent = fmtAxis(t0);
			chartEl.appendChild(xs);
			const xe = mk('text', { x: W - padR, y: H - 8, 'text-anchor': 'end', fill: 'var(--muted-foreground)', 'font-size': '12' });
			xe.textContent = fmtAxis(t1);
			chartEl.appendChild(xe);

			// The line itself (brass/primary chart colour).
			const coords = pts.map((p) => ({ px: x(p.t), py: y(toUnit(p.usd)), t: p.t, usd: p.usd }));
			const d = coords.map((c, i) => `${i ? 'L' : 'M'}${c.px.toFixed(1)},${c.py.toFixed(1)}`).join(' ');
			chartEl.appendChild(mk('path', {
				d, fill: 'none', stroke: 'var(--chart-1)', 'stroke-width': '2.5',
				'stroke-linejoin': 'round', 'stroke-linecap': 'round',
			}));
			// Data dots — only for sparse series; a dense daily line would be noisy
			// with a dot per point, so dot just the endpoints there.
			const dotted = coords.length <= 24 ? coords : [coords[0], coords[coords.length - 1]];
			dotted.forEach((c) => {
				chartEl.appendChild(mk('circle', { cx: c.px, cy: c.py, r: '3', fill: 'var(--chart-1)' }));
			});

			chartGeom = { coords, W, H };
			const fmtDay = (t) => new Date(t).toLocaleDateString('en-AU', { dateStyle: 'medium' });
			chartStatusEl.textContent =
				`Showing ${pts.length} ${pts.length === 1 ? 'point' : 'points'} (${fmtDay(t0)} – ${fmtDay(t1)}), in ${unitLabel()}.`;
		}

		// ---- Tooltip (hover desktop / tap mobile) ----------------------------
		function showTooltipAt(clientX) {
			if (!chartGeom) return;
			const rect = chartEl.getBoundingClientRect();
			// Map pointer x into the SVG's 800-wide viewBox coordinate space.
			const vx = ((clientX - rect.left) / rect.width) * chartGeom.W;
			let nearest = null, best = Infinity;
			for (const c of chartGeom.coords) {
				const dist = Math.abs(c.px - vx);
				if (dist < best) { best = dist; nearest = c; }
			}
			if (!nearest) return;
			const v = toUnit(nearest.usd);
			if (v == null) return;
			const when = new Date(nearest.t).toLocaleDateString('en-AU', { dateStyle: 'medium' });
			tooltipEl.textContent = `${when}: ${fmtAud(v)} (${unitLabel()})`;
			tooltipEl.classList.remove('hidden');
			// Position relative to the wrapper using the dot's SVG coords.
			const wrapRect = chartWrap.getBoundingClientRect();
			const left = (nearest.px / chartGeom.W) * wrapRect.width;
			const top = (nearest.py / chartGeom.H) * wrapRect.height;
			tooltipEl.style.left = `${left}px`;
			tooltipEl.style.top = `${Math.max(top - 6, 12)}px`;
		}
		function hideTooltip() { tooltipEl.classList.add('hidden'); }

		chartWrap.addEventListener('pointermove', (e) => showTooltipAt(e.clientX));
		chartWrap.addEventListener('pointerleave', hideTooltip);
		chartWrap.addEventListener('pointerdown', (e) => showTooltipAt(e.clientX));

		// ---- Controls --------------------------------------------------------
		root.querySelectorAll('[data-gold-unit]').forEach((btn) => {
			btn.addEventListener('click', () => {
				unit = btn.getAttribute('data-gold-unit');
				root.querySelectorAll('[data-gold-unit]').forEach((b) => {
					b.setAttribute('aria-checked', b === btn ? 'true' : 'false');
				});
				renderLatest();
				renderChart();
			});
		});

		root.querySelectorAll('[data-gold-range]').forEach((btn) => {
			btn.addEventListener('click', () => {
				if (btn.disabled) return;
				range = btn.getAttribute('data-gold-range');
				root.querySelectorAll('[data-gold-range]').forEach((b) => {
					b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
				});
				renderChart();
			});
		});

		// ---- Data loading ----------------------------------------------------
		// Validate every third-party shape before trusting it.
		function parseSpot(j) {
			if (j && isFiniteNum(j.price) && j.price > 0) {
				return { price: j.price, updatedAt: j.updatedAt ?? j.updated_at ?? null };
			}
			return null;
		}
		function parseFx(j) {
			const r = j && j.rates && j.rates.AUD;
			return isFiniteNum(r) && r > 0 ? r : null;
		}
		function parseHistory(j) {
			if (!Array.isArray(j)) return [];
			const out = [];
			for (const row of j) {
				if (!row) continue;
				const price = Number(row.price);
				const t = Date.parse(row.date);
				if (isFiniteNum(price) && price > 0 && !isNaN(t)) out.push({ t, usd: price });
			}
			out.sort((a, b) => a.t - b.t);
			return out;
		}

		async function loadLatest() {
			// Fetch spot + FX independently so one failing doesn't void the other.
			const [spotRes, fxRes] = await Promise.allSettled([getJson(SPOT_URL), getJson(FX_URL)]);
			let ok = false;
			if (fxRes.status === 'fulfilled') {
				const r = parseFx(fxRes.value);
				if (r != null) fxRate = r;
			}
			if (spotRes.status === 'fulfilled') {
				const s = parseSpot(spotRes.value);
				if (s) { spotUsd = s.price; spotUpdatedAt = s.updatedAt || new Date().toISOString(); ok = true; }
			}
			if (ok && fxRate != null) {
				renderLatest();
			} else if (latestEl.textContent === '—') {
				// First load failed outright — show a friendly message, don't crash.
				updatedEl.textContent = 'Couldn’t load the latest price right now — will retry shortly.';
			} else {
				// A refresh failed but we already have a price: keep it, note staleness.
				updatedEl.textContent = `${updatedEl.textContent.replace(/ · refresh failed$/, '')} · refresh failed`;
			}
			return ok;
		}

		async function loadHistory() {
			try {
				const j = await getJson(HIST_URL);
				const parsed = parseHistory(j);
				if (parsed.length) history = parsed; // else keep whatever we had
			} catch {
				/* network/parse error — keep the last good history, don't crash */
			}
			renderChart();
		}

		async function init() {
			// Latest first (needs FX, which the chart also needs), then history.
			await loadLatest();
			await loadHistory();
			// If the chart was waiting on FX, this re-render now has it.
			renderChart();

			refreshTimer = setInterval(() => { loadLatest(); }, REFRESH_MS);
		}

		// ClientRouter swaps the DOM without a full reload — stop the timer before
		// the swap so it can't fire against a detached tree or stack on re-entry.
		document.addEventListener('astro:before-swap', () => {
			if (refreshTimer) clearInterval(refreshTimer);
		}, { once: true });

		init();
	})();
</script>
