---
// Polly's Plunder — a BROWSE-ONLY catalogue of parrot apparel & accessories.
//
// CRITICAL: This is purely for fun. There is NO real checkout, NO payment
// provider, NO money handling, NO backend and NO external network calls.
// Every product, price and illustration is STATIC data defined right here in
// the repo; illustrations are inline SVG (no hotlinked images). The "loot bag"
// cart (quantities, running doubloon total, jest checkout) is purely cosmetic
// and persisted to localStorage — no doubloons EVER change hands.
//
// Matches the games / shipyard island pattern: scoped markup, theme-aware
// colours via CSS variables, and a single inline IIFE that re-binds itself on
// Astro client-router swaps. All dynamic text is written via textContent
// (never innerHTML) to avoid injection.

const categories = [
	{ id: 'all', label: 'All Plunder' },
	{ id: 'finery', label: 'Feathered Finery' },
	{ id: 'perch', label: 'Perch Wear' },
	{ id: 'trinkets', label: 'Trinkets & Booty' },
	{ id: 'bundles', label: 'Crew Bundles' },
];

// SVG illustration builders — each draws a self-contained little scene.
const swatch = (bg: string, inner: string) =>
	`<svg viewBox="0 0 120 120" width="100%" height="100%" role="img" preserveAspectRatio="xMidYMid meet" aria-hidden="true">` +
	`<rect width="120" height="120" rx="14" fill="${bg}"/>${inner}</svg>`;

const parrot = (body: string, belly = '#ffd166') =>
	`<g transform="translate(60 64)">` +
	`<ellipse cx="0" cy="6" rx="26" ry="32" fill="${body}"/>` +
	`<ellipse cx="0" cy="14" rx="15" ry="20" fill="${belly}"/>` +
	`<circle cx="0" cy="-26" r="16" fill="${body}"/>` +
	`<circle cx="-5" cy="-28" r="3.2" fill="#1b1b1b"/>` +
	`<path d="M8 -26 q16 0 14 12 q-10 -2 -14 -2 z" fill="#f4a261"/>` +
	`<path d="M-24 -2 q-22 6 -16 30 q14 -8 18 -22 z" fill="${body}" opacity="0.85"/>` +
	`</g>`;

const products = [
	// --- Feathered Finery ---
	{
		id: 'plume-tricorn',
		name: 'The Plumed Tricorn',
		category: 'finery',
		price: '18 doubloons',
		desc: 'A captain\'s hat crowned with scarlet macaw plumes. Squawks optional.',
		svg: swatch('#2a4d69',
			`<path d="M24 78 q36 -34 72 0 q-36 -10 -72 0 z" fill="#3a2417"/>` +
			`<path d="M60 44 q-6 -34 6 -36 q6 14 0 34 z" fill="#e63946"/>` +
			`<path d="M60 44 q10 -30 22 -28 q-2 16 -16 30 z" fill="#f4a261"/>`),
	},
	{
		id: 'rainbow-ruff',
		name: 'Rainbow Wing Ruff',
		category: 'finery',
		price: '14 doubloons',
		desc: 'A collar of cascading feathers — strut the deck like a true lory.',
		svg: swatch('#3d348b',
			`<g transform="translate(60 60)">` +
			`<path d="M0 0 l-30 24 l8 -30 z" fill="#e63946"/>` +
			`<path d="M0 0 l-14 34 l18 -22 z" fill="#f4a261"/>` +
			`<path d="M0 0 l10 34 l8 -30 z" fill="#ffd166"/>` +
			`<path d="M0 0 l30 22 l-2 -30 z" fill="#2a9d8f"/></g>`),
	},
	{
		id: 'beak-bling',
		name: 'Gilded Beak Bling',
		category: 'finery',
		price: '9 doubloons',
		desc: 'A wee gold beak-band for the parrot who already has everything.',
		svg: swatch('#264653',
			parrot('#2a9d8f') +
			`<rect x="64" y="36" width="14" height="5" rx="2.5" fill="#ffd166"/>`),
	},
	// --- Perch Wear ---
	{
		id: 'striped-jumper',
		name: 'Salty Stripes Jumper',
		category: 'perch',
		price: '12 doubloons',
		desc: 'A breton-striped knit so your parrot blends in with the crew.',
		svg: swatch('#1d3557',
			parrot('#457b9d') +
			`<g transform="translate(60 70)"><rect x="-18" y="-4" width="36" height="26" rx="10" fill="#f1faee"/>` +
			`<rect x="-18" y="2" width="36" height="3" fill="#1d3557"/>` +
			`<rect x="-18" y="10" width="36" height="3" fill="#1d3557"/></g>`),
	},
	{
		id: 'tiny-raincoat',
		name: 'Stormy Seas Raincoat',
		category: 'perch',
		price: '15 doubloons',
		desc: 'Wee yellow oilskins for squally days at the rail. Hood included.',
		svg: swatch('#386641',
			parrot('#6a994e') +
			`<g transform="translate(60 72)"><path d="M-18 -6 q18 -10 36 0 l4 28 l-44 0 z" fill="#ffd166"/>` +
			`<path d="M-18 -6 q18 12 36 0" fill="none" stroke="#e6a700" stroke-width="2"/></g>`),
	},
	{
		id: 'pirate-bandana',
		name: 'Buccaneer Bandana',
		category: 'perch',
		price: '7 doubloons',
		desc: 'A crimson head-scarf. Instantly 40% more roguish, scientists say.',
		svg: swatch('#6d597a',
			parrot('#e07a5f') +
			`<g transform="translate(60 38)"><path d="M-16 0 q16 -14 32 0 q-16 6 -32 0 z" fill="#e63946"/>` +
			`<path d="M14 0 l12 8 l-8 2 z" fill="#c1121f"/></g>`),
	},
	{
		id: 'cabin-cardigan',
		name: 'Cabin-Boy Cardigan',
		category: 'perch',
		price: '13 doubloons',
		desc: 'Cosy, buttoned and quietly distinguished. For the studious parrot.',
		svg: swatch('#22223b',
			parrot('#9a8c98', '#f2e9e4') +
			`<g transform="translate(60 70)"><rect x="-16" y="-2" width="32" height="24" rx="8" fill="#c9ada7"/>` +
			`<circle cx="0" cy="6" r="2" fill="#4a4e69"/><circle cx="0" cy="14" r="2" fill="#4a4e69"/></g>`),
	},
	// --- Trinkets & Booty ---
	{
		id: 'cracker-medallion',
		name: 'Cracker Medallion',
		category: 'trinkets',
		price: '6 doubloons',
		desc: 'A polished pendant shaped like the noblest of crackers. Polly approved.',
		svg: swatch('#3a0ca3',
			`<circle cx="60" cy="60" r="28" fill="#ffd166" stroke="#e6a700" stroke-width="4"/>` +
			`<circle cx="50" cy="50" r="3" fill="#c98a00"/><circle cx="70" cy="54" r="3" fill="#c98a00"/>` +
			`<circle cx="58" cy="68" r="3" fill="#c98a00"/><circle cx="72" cy="70" r="3" fill="#c98a00"/>`),
	},
	{
		id: 'spyglass-charm',
		name: 'Spyglass Charm',
		category: 'trinkets',
		price: '8 doubloons',
		desc: 'A brass mini-spyglass on a chain. Cannot actually see distant ships.',
		svg: swatch('#005f73',
			`<g transform="translate(60 60) rotate(-30)"><rect x="-30" y="-6" width="26" height="12" rx="3" fill="#caa472"/>` +
			`<rect x="-4" y="-8" width="20" height="16" rx="3" fill="#8d6e3f"/>` +
			`<rect x="16" y="-9" width="6" height="18" rx="2" fill="#ffd166"/></g>`),
	},
	{
		id: 'treasure-keyring',
		name: 'Buried-Treasure Keyring',
		category: 'trinkets',
		price: '5 doubloons',
		desc: 'A tiny treasure chest that jangles. Contains zero (0) actual gold.',
		svg: swatch('#9d0208',
			`<g transform="translate(60 64)"><rect x="-26" y="-2" width="52" height="30" rx="4" fill="#6b4423"/>` +
			`<path d="M-26 -2 q26 -22 52 0 z" fill="#8d6e3f"/>` +
			`<rect x="-26" y="8" width="52" height="6" fill="#ffd166"/>` +
			`<rect x="-4" y="6" width="8" height="12" fill="#ffd166"/></g>`),
	},
	// --- Crew Bundles ---
	{
		id: 'first-mate-bundle',
		name: 'First-Mate Starter Bundle',
		category: 'bundles',
		price: '30 doubloons',
		desc: 'Bandana, striped jumper and a cracker medallion — kit out a new recruit.',
		svg: swatch('#283618',
			parrot('#bc6c25') +
			`<g transform="translate(60 36)"><path d="M-14 0 q14 -12 28 0 q-14 6 -28 0 z" fill="#e63946"/></g>` +
			`<g transform="translate(60 72)"><rect x="-16" y="-2" width="32" height="22" rx="8" fill="#f1faee"/>` +
			`<rect x="-16" y="4" width="32" height="3" fill="#283618"/></g>`),
	},
	{
		id: 'captains-chest',
		name: 'Captain\'s Grand Chest',
		category: 'bundles',
		price: '52 doubloons',
		desc: 'The lot: tricorn, ruff, raincoat and every trinket. The full plunder haul.',
		svg: swatch('#370617',
			`<g transform="translate(60 66)"><rect x="-34" y="-4" width="68" height="36" rx="5" fill="#6b4423"/>` +
			`<path d="M-34 -4 q34 -26 68 0 z" fill="#8d6e3f"/>` +
			`<rect x="-34" y="8" width="68" height="7" fill="#ffd166"/>` +
			`<rect x="-6" y="4" width="12" height="16" fill="#ffd166"/>` +
			`<circle cx="-20" cy="-18" r="5" fill="#e63946"/><circle cx="6" cy="-22" r="5" fill="#2a9d8f"/>` +
			`<circle cx="22" cy="-16" r="5" fill="#ffd166"/></g>`),
	},
];
---

<section
	id="plunder"
	class="flex flex-col gap-6 rounded-xl border bg-card p-5 text-card-foreground shadow-sm"
>
	<!-- Cosmetic-cart notice -->
	<p class="rounded-lg border border-dashed bg-background px-4 py-3 text-sm text-muted-foreground">
		🦜 <strong>Just for fun, me hearty.</strong> Polly's Plunder is a make-believe
		market — this be just for fun, no real doubloons charged. There be no checkout,
		no payments and no real wares: your loot bag lives only in this browser.
	</p>

	<!-- Filter tabs + loot-bag button -->
	<div class="flex flex-wrap items-center justify-between gap-3">
		<nav id="pp-filters" class="flex flex-wrap gap-2" aria-label="Filter plunder by range">
			{categories.map((c) => (
				<button
					type="button"
					class="pp-filter rounded-full border bg-background px-3 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
					data-cat={c.id}
					aria-pressed={c.id === 'all' ? 'true' : 'false'}
				>{c.label}</button>
			))}
		</nav>

		<button
			id="pp-booty-toggle"
			type="button"
			class="rounded-md border bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:opacity-90 focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
			aria-haspopup="dialog"
			aria-expanded="false"
			aria-controls="pp-booty-panel"
		>🎒 Loot bag (<span id="pp-booty-count">0</span>)</button>
	</div>

	<!-- Loot-bag drawer (cosmetic, local only). A right-hand slide-out panel. -->
	<div
		id="pp-booty-overlay"
		hidden
		class="fixed inset-0 z-40 bg-black/40 backdrop-blur-[1px]"
	></div>
	<aside
		id="pp-booty-panel"
		hidden
		role="dialog"
		aria-modal="true"
		aria-labelledby="pp-booty-title"
		tabindex="-1"
		class="fixed inset-y-0 right-0 z-50 flex w-full max-w-sm flex-col gap-4 border-l bg-background p-5 shadow-2xl outline-none"
	>
		<div class="flex items-center justify-between gap-2">
			<h2 id="pp-booty-title" class="text-lg font-semibold tracking-tight">Yer Loot Bag 🎒</h2>
			<button
				id="pp-booty-close"
				type="button"
				aria-label="Close loot bag"
				class="rounded-md border px-2 py-1 text-sm text-muted-foreground hover:text-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
			>✕</button>
		</div>

		<!-- Scrolling list of looted wares with qty controls -->
		<ul id="pp-booty-list" class="flex flex-1 flex-col gap-2 overflow-y-auto text-sm"></ul>

		<p id="pp-booty-empty" class="flex-1 text-sm text-muted-foreground">
			Yer bag be lighter than a gull's feather. Plunder a trinket or two —
			it's all pretend, naturally, so go wild, ye magnificent scallywag.
		</p>

		<!-- Running total -->
		<div class="flex items-center justify-between border-t pt-3 text-sm font-medium">
			<span>Total plunder</span>
			<span
				id="pp-booty-total"
				aria-live="polite"
				class="tabular-nums"
			>0 doubloons</span>
		</div>

		<div class="flex flex-col gap-2">
			<button
				id="pp-booty-checkout"
				type="button"
				class="rounded-md border bg-primary px-3 py-2 text-sm font-medium text-primary-foreground transition-colors hover:opacity-90 focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none disabled:cursor-not-allowed disabled:opacity-50"
			>Plunder responsibly (jest checkout) 🏴‍☠️</button>
			<button
				id="pp-booty-clear"
				type="button"
				class="rounded-md border px-2 py-1 text-xs text-muted-foreground hover:text-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
			>Empty the bag</button>
		</div>

		<!-- Jest-checkout receipt (a goofy keepsake; no money moved) -->
		<div
			id="pp-booty-receipt"
			hidden
			role="status"
			class="flex flex-col gap-2 rounded-lg border border-dashed bg-card p-4 text-sm text-card-foreground"
		>
			<p class="text-base font-semibold">🦜 Ye plundered responsibly!</p>
			<p id="pp-receipt-line" class="text-muted-foreground"></p>
			<p class="text-2xl font-bold tabular-nums text-primary">0 doubloons taken</p>
			<p class="text-xs text-muted-foreground">
				No order was placed. No doubloons were charged. Nothing was sent
				anywhere. 'Twas all a jolly jest — yer real coin is safe in its chest.
			</p>
			<button
				id="pp-receipt-dismiss"
				type="button"
				class="self-start rounded-md border px-2 py-1 text-xs text-muted-foreground hover:text-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
			>Aye, splendid</button>
		</div>

		<p class="text-xs text-muted-foreground">
			This bag is purely cosmetic and stored only in your browser. No order is
			placed, no doubloons are charged, nothing is sent anywhere.
		</p>
	</aside>

	<!-- Product grid -->
	<div
		id="pp-grid"
		class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
	>
		{products.map((p) => (
			<article
				class="pp-card flex flex-col gap-3 rounded-lg border bg-background p-4"
				data-cat={p.category}
			>
				<div
					class="aspect-square overflow-hidden rounded-md border bg-card"
					set:html={p.svg}
				/>
				<div class="flex items-start justify-between gap-2">
					<h3 class="text-base font-semibold leading-tight">{p.name}</h3>
					<span class="shrink-0 rounded-full border bg-card px-2 py-0.5 text-xs font-medium text-muted-foreground">{p.price}</span>
				</div>
				<p class="text-sm text-muted-foreground">{p.desc}</p>
				<button
					type="button"
					class="pp-add mt-auto rounded-md border bg-primary px-3 py-2 text-sm font-medium text-primary-foreground transition-colors hover:opacity-90 focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
					data-id={p.id}
					data-name={p.name}
					data-price={p.price}
				>Add to bag 🏴‍☠️</button>
			</article>
		))}
	</div>

	<p id="pp-no-results" hidden class="text-sm text-muted-foreground">
		No plunder in this range yet — try another, matey.
	</p>
</section>

<style>
	#plunder .pp-filter[aria-pressed="true"] {
		border-color: var(--primary);
		background-color: color-mix(in srgb, var(--primary) 15%, transparent);
		color: var(--foreground);
	}
	#pp-booty-panel {
		transition: transform 0.2s ease;
	}
	#pp-booty-panel[hidden] {
		display: none;
	}
	@media (prefers-reduced-motion: reduce) {
		#pp-booty-panel { transition: none; }
	}
</style>

<script is:inline>
	(() => {
		const root = document.getElementById('plunder');
		if (!root || root.dataset.bound === '1') return;
		root.dataset.bound = '1';

		// Cosmetic, local-only loot bag. Reuses the existing key so older booty
		// sacks (flat {name, price} arrays) migrate forward into the new model.
		const STORE_KEY = 'pollys-plunder-booty';
		const MAX_LINES = 60;   // distinct products
		const MAX_QTY = 99;     // per product

		const cards = Array.from(root.querySelectorAll('.pp-card'));
		const filters = Array.from(root.querySelectorAll('.pp-filter'));
		const noResults = document.getElementById('pp-no-results');

		const bootyToggle = document.getElementById('pp-booty-toggle');
		const overlay = document.getElementById('pp-booty-overlay');
		const bootyPanel = document.getElementById('pp-booty-panel');
		const bootyCount = document.getElementById('pp-booty-count');
		const bootyList = document.getElementById('pp-booty-list');
		const bootyEmpty = document.getElementById('pp-booty-empty');
		const bootyTotal = document.getElementById('pp-booty-total');
		const bootyClear = document.getElementById('pp-booty-clear');
		const bootyClose = document.getElementById('pp-booty-close');
		const checkoutBtn = document.getElementById('pp-booty-checkout');
		const receipt = document.getElementById('pp-booty-receipt');
		const receiptLine = document.getElementById('pp-receipt-line');
		const receiptDismiss = document.getElementById('pp-receipt-dismiss');

		// Parse the leading number out of a price string like "18 doubloons".
		function priceNum(price) {
			const m = String(price).match(/\d+/);
			return m ? parseInt(m[0], 10) : 0;
		}

		// ---- Cosmetic local-only loot store (guarded against bad data) ----
		// Model: array of { id, name, price, qty }. Old flat arrays of
		// { name, price } are coalesced by name into qty'd lines on load.
		function load() {
			try {
				const raw = localStorage.getItem(STORE_KEY);
				if (!raw) return [];
				const arr = JSON.parse(raw);
				if (!Array.isArray(arr)) return [];
				const byKey = new Map();
				for (const i of arr) {
					if (!i || typeof i !== 'object') continue;
					if (typeof i.name !== 'string' || typeof i.price !== 'string') continue;
					const name = i.name.slice(0, 80);
					const price = i.price.slice(0, 40);
					const id = typeof i.id === 'string' ? i.id.slice(0, 80) : name;
					let qty = Number.isFinite(i.qty) ? Math.floor(i.qty) : 1;
					if (qty < 1) qty = 1;
					if (qty > MAX_QTY) qty = MAX_QTY;
					const existing = byKey.get(id);
					if (existing) {
						existing.qty = Math.min(MAX_QTY, existing.qty + qty);
					} else if (byKey.size < MAX_LINES) {
						byKey.set(id, { id, name, price, qty });
					}
				}
				return Array.from(byKey.values());
			} catch { return []; }
		}
		function save(items) {
			try { localStorage.setItem(STORE_KEY, JSON.stringify(items)); } catch {}
		}

		function totals(items) {
			let units = 0;
			let doubloons = 0;
			for (const i of items) {
				units += i.qty;
				doubloons += priceNum(i.price) * i.qty;
			}
			return { units, doubloons };
		}

		// Mutate one line's qty by delta; remove when it hits zero.
		function changeQty(id, delta) {
			const items = load();
			const idx = items.findIndex((i) => i.id === id);
			if (idx === -1) return;
			items[idx].qty += delta;
			if (items[idx].qty < 1) items.splice(idx, 1);
			else if (items[idx].qty > MAX_QTY) items[idx].qty = MAX_QTY;
			save(items);
			renderBooty();
		}
		function removeLine(id) {
			save(load().filter((i) => i.id !== id));
			renderBooty();
		}

		function makeBtn(label, ariaLabel, cls) {
			const b = document.createElement('button');
			b.type = 'button';
			b.className = cls;
			b.textContent = label;          // textContent — no innerHTML
			b.setAttribute('aria-label', ariaLabel);
			return b;
		}

		function renderBooty() {
			const items = load();
			const { units, doubloons } = totals(items);
			bootyCount.textContent = String(units);
			bootyTotal.textContent = doubloons + (doubloons === 1 ? ' doubloon' : ' doubloons');
			bootyEmpty.hidden = items.length > 0;
			checkoutBtn.disabled = items.length === 0;

			bootyList.textContent = '';
			items.forEach((item) => {
				const li = document.createElement('li');
				li.className = 'flex flex-col gap-1 rounded-md border bg-card p-2';

				const top = document.createElement('div');
				top.className = 'flex items-start justify-between gap-2';
				const name = document.createElement('span');
				name.className = 'font-medium leading-tight';
				name.textContent = item.name;     // textContent — no injection
				const price = document.createElement('span');
				price.className = 'shrink-0 text-xs text-muted-foreground';
				price.textContent = item.price;
				top.append(name, price);

				const bottom = document.createElement('div');
				bottom.className = 'flex items-center justify-between gap-2';

				const stepper = document.createElement('div');
				stepper.className = 'flex items-center gap-1';
				const dec = makeBtn('−', 'Remove one ' + item.name,
					'rounded border px-2 py-0.5 text-sm leading-none hover:bg-background focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none');
				const qty = document.createElement('span');
				qty.className = 'min-w-6 text-center text-sm tabular-nums';
				qty.setAttribute('aria-label', 'Quantity of ' + item.name);
				qty.textContent = String(item.qty);
				const inc = makeBtn('+', 'Add one ' + item.name,
					'rounded border px-2 py-0.5 text-sm leading-none hover:bg-background focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none');
				dec.addEventListener('click', () => changeQty(item.id, -1));
				inc.addEventListener('click', () => changeQty(item.id, 1));
				stepper.append(dec, qty, inc);

				const lineTotal = document.createElement('span');
				lineTotal.className = 'text-xs tabular-nums text-muted-foreground';
				lineTotal.textContent = (priceNum(item.price) * item.qty) + ' db';

				const remove = makeBtn('Remove', 'Remove ' + item.name + ' from loot bag',
					'rounded border px-2 py-0.5 text-xs text-muted-foreground hover:text-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none');
				remove.addEventListener('click', () => removeLine(item.id));

				bottom.append(stepper, lineTotal, remove);
				li.append(top, bottom);
				bootyList.appendChild(li);
			});
		}

		// ---- Add to bag ----
		root.querySelectorAll('.pp-add').forEach((btn) => {
			btn.addEventListener('click', () => {
				const id = btn.getAttribute('data-id') || (btn.getAttribute('data-name') || 'mystery');
				const name = btn.getAttribute('data-name') || 'Mystery plunder';
				const price = btn.getAttribute('data-price') || '? doubloons';
				const items = load();
				const existing = items.find((i) => i.id === id);
				if (existing) {
					existing.qty = Math.min(MAX_QTY, existing.qty + 1);
				} else if (items.length < MAX_LINES) {
					items.push({ id, name, price, qty: 1 });
				}
				save(items);
				renderBooty();
				hideReceipt();
				const original = btn.textContent;
				btn.textContent = 'In yer bag! 🦜';
				btn.disabled = true;
				setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 900);
			});
		});

		// ---- Loot-bag drawer open/close ----
		let lastFocus = null;
		function openBag() {
			lastFocus = document.activeElement;
			overlay.hidden = false;
			bootyPanel.hidden = false;
			bootyToggle.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
			bootyPanel.focus();
		}
		function closeBag() {
			overlay.hidden = true;
			bootyPanel.hidden = true;
			bootyToggle.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
			if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
			else bootyToggle.focus();
		}
		function isOpen() { return !bootyPanel.hidden; }

		bootyToggle.addEventListener('click', () => { isOpen() ? closeBag() : openBag(); });
		bootyClose.addEventListener('click', closeBag);
		overlay.addEventListener('click', closeBag);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && isOpen()) closeBag();
		});

		// ---- Empty + jest checkout ----
		function hideReceipt() { receipt.hidden = true; }
		bootyClear.addEventListener('click', () => {
			save([]);
			renderBooty();
			hideReceipt();
		});
		checkoutBtn.addEventListener('click', () => {
			const items = load();
			if (items.length === 0) return;
			const { units, doubloons } = totals(items);
			receiptLine.textContent =
				'Ye hauled ' + units + (units === 1 ? ' fine ware' : ' fine wares') +
				' worth a make-believe ' + doubloons +
				(doubloons === 1 ? ' doubloon' : ' doubloons') +
				' — and paid not a single one.';
			receipt.hidden = false;
			receipt.scrollIntoView({ block: 'nearest' });
			receiptDismiss.focus();
		});
		receiptDismiss.addEventListener('click', () => {
			hideReceipt();
			bootyToggle.focus();
		});

		// ---- Category filter ----
		function applyFilter(cat) {
			let shown = 0;
			cards.forEach((card) => {
				const match = cat === 'all' || card.getAttribute('data-cat') === cat;
				card.hidden = !match;
				if (match) shown++;
			});
			noResults.hidden = shown > 0;
			filters.forEach((f) =>
				f.setAttribute('aria-pressed', f.getAttribute('data-cat') === cat ? 'true' : 'false'));
		}
		filters.forEach((f) => {
			f.addEventListener('click', () => applyFilter(f.getAttribute('data-cat')));
		});

		// ---- Init ----
		applyFilter('all');
		renderBooty();

		// Astro client-router: drop the lock + body style and let the swapped-in
		// DOM re-bind its own fresh listeners on next render.
		document.addEventListener('astro:before-swap', () => {
			document.body.style.overflow = '';
			root.dataset.bound = '';
		}, { once: true });
	})();
</script>
