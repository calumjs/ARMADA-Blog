---
// KrakenEasterEgg — a hidden "Release the Kraken" flourish.
//
// A secret key trigger (the Konami code, OR typing the word "kraken") summons a
// dismissible animated kraken: inline SVG tentacles rising over the viewport with
// CSS @keyframes. Purely decorative & client-side — no backend, no audio. The
// overlay is SSR'd hidden (display:none via [hidden]) so there's no layout shift to
// the page underneath; it only paints once the secret is entered.
//
// The key listener is delegated from `document` and guarded by a window flag so it
// survives Astro ClientRouter route swaps and Tina re-renders (same convention as
// ThemeToggle.astro). It ignores keystrokes while focus is in a form field
// (<input>/<textarea>/[contenteditable]) and fires its full animation once per page
// session. Styling uses the maritime theme tokens from global.css.
---

<div
	id="kraken-overlay"
	class="kraken-overlay"
	role="dialog"
	aria-modal="true"
	aria-label="Release the Kraken!"
	hidden
>
	<button type="button" class="kraken-dismiss" aria-label="Dismiss the kraken (Escape)">
		&times;
	</button>

	<!-- Decorative sea monster — purely illustrative, hidden from AT. -->
	<svg
		class="kraken-art"
		viewBox="0 0 800 600"
		preserveAspectRatio="xMidYMax slice"
		aria-hidden="true"
		focusable="false"
	>
		<defs>
			<radialGradient id="kraken-eye" cx="50%" cy="45%" r="55%">
				<stop offset="0%" stop-color="oklch(0.95 0.16 95)" />
				<stop offset="60%" stop-color="oklch(0.78 0.18 78)" />
				<stop offset="100%" stop-color="oklch(0.40 0.07 250)" />
			</radialGradient>
		</defs>

		<!-- Tentacles: each rises from below the viewport on its own delay. -->
		<g class="kraken-tentacles" fill="currentColor">
			<path class="kraken-tentacle kt-1" d="M120 640 C 90 480 200 420 150 280 C 120 200 60 200 40 120 C 90 180 150 200 175 300 C 200 440 175 520 200 640 Z" />
			<path class="kraken-tentacle kt-2" d="M260 640 C 240 460 320 420 300 300 C 290 220 250 200 260 120 C 300 200 340 240 340 340 C 340 480 320 540 330 640 Z" />
			<path class="kraken-tentacle kt-3" d="M540 640 C 560 460 480 420 500 300 C 510 220 550 200 540 120 C 500 200 460 240 460 340 C 460 480 480 540 470 640 Z" />
			<path class="kraken-tentacle kt-4" d="M680 640 C 710 480 600 420 650 280 C 680 200 740 200 760 120 C 710 180 650 200 625 300 C 600 440 625 520 600 640 Z" />
			<path class="kraken-tentacle kt-5" d="M400 640 C 380 440 420 420 410 260 C 405 180 395 180 400 100 C 410 180 430 220 430 320 C 430 480 420 540 460 640 Z" />
		</g>

		<!-- Mantle / head rising in the centre. -->
		<g class="kraken-head">
			<path
				fill="currentColor"
				d="M400 640 C 250 640 230 460 250 360 C 270 250 330 200 400 200 C 470 200 530 250 550 360 C 570 460 550 640 400 640 Z"
			/>
			<circle cx="345" cy="370" r="34" fill="url(#kraken-eye)" />
			<circle cx="455" cy="370" r="34" fill="url(#kraken-eye)" />
			<circle cx="345" cy="375" r="13" fill="oklch(0.18 0.04 252)" />
			<circle cx="455" cy="375" r="13" fill="oklch(0.18 0.04 252)" />
		</g>
	</svg>

	<p class="kraken-caption">Release the Kraken! &mdash; click anywhere or press Esc</p>
</div>

<style>
	.kraken-overlay {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		/* Deep-water wash over the page, tinted with the ocean-navy token. */
		background:
			radial-gradient(120% 90% at 50% 110%, oklch(0.19 0.04 252 / 0.92), oklch(0.19 0.04 252 / 0.55) 70%, transparent),
			oklch(0.19 0.04 252 / 0.35);
		color: var(--primary);
		cursor: pointer;
		overflow: hidden;
		animation: kraken-fade-in 360ms ease-out both;
	}

	.kraken-overlay[hidden] {
		display: none;
	}

	.kraken-art {
		width: min(90vw, 760px);
		height: min(80vh, 600px);
		color: var(--primary);
		filter: drop-shadow(0 0 28px oklch(0.46 0.085 220 / 0.6));
	}

	.kraken-head {
		transform-origin: 50% 100%;
		animation: kraken-rise 1100ms cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 200ms;
	}

	.kraken-tentacle {
		transform-origin: 50% 100%;
		transform: translateY(110%);
		animation: kraken-tentacle-rise 1200ms cubic-bezier(0.22, 1, 0.36, 1) both;
	}

	/* Stagger + gentle sway on the tentacles for that summoned-from-the-deep feel. */
	.kt-1 { animation-delay: 80ms; }
	.kt-2 { animation-delay: 220ms; }
	.kt-3 { animation-delay: 300ms; }
	.kt-4 { animation-delay: 160ms; }
	.kt-5 { animation-delay: 380ms; }

	.kraken-caption {
		position: absolute;
		bottom: clamp(1rem, 4vh, 3rem);
		left: 50%;
		transform: translateX(-50%);
		margin: 0;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-md);
		background: oklch(0.19 0.04 252 / 0.6);
		color: var(--primary-foreground);
		font-family: var(--font-serif);
		font-size: clamp(0.9rem, 2.4vw, 1.2rem);
		letter-spacing: 0.02em;
		text-align: center;
		animation: kraken-fade-in 500ms ease-out both;
		animation-delay: 700ms;
	}

	.kraken-dismiss {
		position: absolute;
		top: clamp(0.75rem, 3vh, 1.5rem);
		right: clamp(0.75rem, 3vw, 1.5rem);
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border: 1px solid oklch(0.55 0.11 78 / 0.6);
		border-radius: var(--radius-md);
		background: oklch(0.24 0.045 252 / 0.7);
		color: var(--primary-foreground);
		font-size: 1.75rem;
		line-height: 1;
		cursor: pointer;
		transition: background-color 150ms ease, color 150ms ease;
	}

	.kraken-dismiss:hover {
		background: oklch(0.46 0.085 220 / 0.9);
		color: oklch(0.98 0.014 90);
	}

	.kraken-dismiss:focus-visible {
		outline: none;
		box-shadow: 0 0 0 3px oklch(0.55 0.11 78 / 0.5);
	}

	@keyframes kraken-fade-in {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes kraken-rise {
		from { transform: translateY(80%); opacity: 0; }
		60% { opacity: 1; }
		to { transform: translateY(0); opacity: 1; }
	}

	@keyframes kraken-tentacle-rise {
		from { transform: translateY(110%); }
		70% { transform: translateY(-4%) rotate(1.5deg); }
		to { transform: translateY(0) rotate(0); }
	}

	/* Reduced motion: no rising/sway — reveal a quick, static kraken instead. */
	@media (prefers-reduced-motion: reduce) {
		.kraken-overlay { animation: kraken-fade-in 120ms ease-out both; }
		.kraken-head,
		.kraken-tentacle,
		.kraken-caption {
			animation: none;
			transform: none;
			opacity: 1;
		}
	}
</style>

<script is:inline>
	// Delegate from document so the listener survives DOM swaps from Astro's
	// ClientRouter and Tina's visual-editor re-renders. Guard with a window flag
	// (same convention as ThemeToggle.astro) so it binds exactly once per session.
	if (!window.__krakenBound) {
		window.__krakenBound = true;

		// Konami: up up down down left right left right b a
		var KONAMI = [
			'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
			'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
			'b', 'a',
		];
		var WORD = 'kraken';

		var konamiPos = 0;
		var wordBuf = '';
		var active = false;

		function isTyping(el) {
			if (!el) return false;
			var tag = el.tagName;
			if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
			if (el.isContentEditable) return true;
			return false;
		}

		function overlay() {
			return document.getElementById('kraken-overlay');
		}

		function release() {
			if (active) return;
			var el = overlay();
			if (!el) return;
			active = true;
			konamiPos = 0;
			wordBuf = '';
			el.hidden = false;
			// Restart the entrance animation if it was shown before this swap.
			void el.offsetWidth;
		}

		function dismiss() {
			var el = overlay();
			if (el) el.hidden = true;
			active = false;
		}

		document.addEventListener('keydown', function (e) {
			// Never fire while the user is typing into a form field.
			if (isTyping(e.target)) return;

			if (active) {
				if (e.key === 'Escape') dismiss();
				return;
			}

			// Konami sequence (case-insensitive on the b/a keys).
			var expected = KONAMI[konamiPos];
			var matches = e.key === expected
				|| (expected.length === 1 && e.key.toLowerCase() === expected.toLowerCase());
			konamiPos = matches ? konamiPos + 1 : (e.key === KONAMI[0] ? 1 : 0);
			if (konamiPos >= KONAMI.length) {
				release();
				return;
			}

			// Rolling buffer for the secret word.
			if (e.key.length === 1 && /[a-z]/i.test(e.key)) {
				wordBuf = (wordBuf + e.key.toLowerCase()).slice(-WORD.length);
				if (wordBuf === WORD) {
					release();
					return;
				}
			}
		});

		// Click anywhere on the overlay dismisses it (includes the explicit button).
		document.addEventListener('click', function (e) {
			var el = overlay();
			if (!el || el.hidden) return;
			if (el === e.target || el.contains(e.target)) dismiss();
		});

		// Tidy up before an Astro route swap so a fresh page starts clean.
		document.addEventListener('astro:before-swap', dismiss);
	}
</script>
