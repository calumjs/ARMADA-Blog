---
/**
 * TideClock — a small decorative footer widget showing a *pseudo* tide phase.
 *
 * Purely local math, no network/API and no geolocation: the phase is derived
 * from a documented fixed epoch and the principal lunar semi-diurnal (M2)
 * period of 12h25m. It is deterministic "flavour", not real tide data.
 *
 *   epoch  = 2026-01-01T00:00:00Z   (treated as a reference HIGH water)
 *   period = 12h 25m = 44,700,000 ms
 *   phase  = ((now - epoch) mod period) / period   ∈ [0, 1)
 *            0 → high water, 0.5 → low water; falling in (0, 0.5),
 *            rising in [0.5, 1).
 *
 * The dial is a tide-clock face (high water at the top, low at the bottom)
 * whose needle sweeps once per period. The label reads e.g.
 * "Tide: rising (3h 12m to high water)".
 *
 * Behaviour requirements (issue #195):
 *  - updates at most once per minute; the interval is torn down while the
 *    tab is hidden and re-primed on return;
 *  - themed exclusively via the global CSS variables so it stays legible in
 *    all five themes;
 *  - the wrapper carries a live aria-label describing the state;
 *  - prefers-reduced-motion disables the needle transition (discrete jumps).
 *
 * The footer lives inside a Tina island that can be re-rendered by the
 * visual editor, so — like ThemeToggle — the script binds once on `window`
 * and re-queries `[data-tide-clock]` on every tick instead of holding
 * element references.
 */
---
<div
	data-tide-clock
	role="img"
	aria-label="Tide clock loading"
	title="Decorative pseudo-tide clock (fixed epoch, 12h25m cycle — not real tide data)"
	class="tide-clock inline-flex items-center gap-2.5 rounded-full border bg-card/60 py-1.5 pl-1.5 pr-4 text-xs text-muted-foreground shadow-xs"
>
	<svg
		viewBox="0 0 40 40"
		class="tide-clock-face size-7 shrink-0"
		aria-hidden="true"
	>
		<!-- face -->
		<circle cx="20" cy="20" r="18" fill="var(--card)" stroke="var(--border)" stroke-width="1.5" />
		<!-- high-water tick (top) + low-water tick (bottom) -->
		<line x1="20" y1="4.5" x2="20" y2="9" stroke="var(--muted-foreground)" stroke-width="2" stroke-linecap="round" />
		<line x1="20" y1="31" x2="20" y2="35.5" stroke="var(--muted-foreground)" stroke-width="1.5" stroke-linecap="round" />
		<!-- quarter ticks -->
		<line x1="4.5" y1="20" x2="8" y2="20" stroke="var(--muted-foreground)" stroke-width="1" stroke-linecap="round" opacity="0.6" />
		<line x1="32" y1="20" x2="35.5" y2="20" stroke="var(--muted-foreground)" stroke-width="1" stroke-linecap="round" opacity="0.6" />
		<!-- needle: drawn pointing up (high water); rotated by script -->
		<g data-tide-needle class="tide-clock-needle">
			<line x1="20" y1="20" x2="20" y2="7.5" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" />
		</g>
		<circle cx="20" cy="20" r="2" fill="var(--primary)" />
	</svg>
	<span data-tide-label aria-hidden="true">Tide: &hellip;</span>
</div>

<style>
	.tide-clock-needle {
		transform-origin: 20px 20px;
		/* Gentle sweep between the once-a-minute updates… */
		transition: transform 0.8s ease-in-out;
	}
	/* …but discrete jumps only for users who prefer reduced motion. */
	@media (prefers-reduced-motion: reduce) {
		.tide-clock-needle {
			transition: none;
		}
	}
</style>

<script is:inline>
	// Bound once on window so the loop survives Astro route swaps and Tina
	// visual-editor re-renders of the footer island (which replace the DOM).
	if (!window.__tideClockBound) {
		window.__tideClockBound = true;

		// Documented fixed epoch (reference high water) + M2 lunar period.
		var TIDE_EPOCH_MS = Date.UTC(2026, 0, 1, 0, 0, 0); // 2026-01-01T00:00:00Z
		var TIDE_PERIOD_MS = (12 * 60 + 25) * 60 * 1000;   // 12h25m = 44,700,000 ms

		function formatDuration(ms, long) {
			var totalMinutes = Math.round(ms / 60000);
			var h = Math.floor(totalMinutes / 60);
			var m = totalMinutes % 60;
			if (long) {
				var parts = [];
				if (h > 0) parts.push(h + (h === 1 ? ' hour' : ' hours'));
				parts.push(m + (m === 1 ? ' minute' : ' minutes'));
				return parts.join(' ');
			}
			return h > 0 ? h + 'h ' + m + 'm' : m + 'm';
		}

		function renderTideClocks() {
			var clocks = document.querySelectorAll('[data-tide-clock]');
			if (clocks.length === 0) return;

			var elapsed = Date.now() - TIDE_EPOCH_MS;
			// Normalised phase in [0, 1): 0 = high water, 0.5 = low water.
			var phase = ((elapsed % TIDE_PERIOD_MS) + TIDE_PERIOD_MS) % TIDE_PERIOD_MS / TIDE_PERIOD_MS;
			var rising = phase >= 0.5;
			var msToHigh = (1 - phase) * TIDE_PERIOD_MS;
			// Continuous (non-wrapped) angle so the animated needle never
			// sweeps backwards across the 360° → 0° boundary.
			var angle = (elapsed / TIDE_PERIOD_MS) * 360;

			var state = rising ? 'rising' : 'falling';
			var label = 'Tide: ' + state + ' (' + formatDuration(msToHigh, false) + ' to high water)';
			var aria = 'Tide clock: tide ' + state + ', ' + formatDuration(msToHigh, true) +
				' until high water. Decorative pseudo-tide, not real tide data.';

			clocks.forEach(function (clock) {
				clock.setAttribute('aria-label', aria);
				var needle = clock.querySelector('[data-tide-needle]');
				if (needle) needle.style.transform = 'rotate(' + angle + 'deg)';
				var text = clock.querySelector('[data-tide-label]');
				if (text) text.textContent = label;
			});
		}

		var tideTimer = null;

		function startTideLoop() {
			if (tideTimer !== null) return;
			renderTideClocks();
			// At most one update per minute while the tab is visible.
			tideTimer = window.setInterval(renderTideClocks, 60000);
		}

		function stopTideLoop() {
			if (tideTimer !== null) {
				window.clearInterval(tideTimer);
				tideTimer = null;
			}
		}

		// Pause while hidden; re-prime immediately on return.
		document.addEventListener('visibilitychange', function () {
			if (document.hidden) stopTideLoop();
			else startTideLoop();
		});

		// Repaint fresh DOM after client-side route swaps.
		document.addEventListener('astro:after-swap', renderTideClocks);

		if (!document.hidden) startTideLoop();
	}
</script>
