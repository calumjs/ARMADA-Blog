---
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---
<div aria-hidden="true" class={`pointer-events-none absolute inset-0 overflow-hidden ${className}`}>
	{/* Sea-glow: a weathered-teal tide of light up top with a brass horizon
	   beneath, replacing the old warm aurora to suit the maritime palette. */}
	<div
		class="absolute left-1/2 top-0 h-[42rem] w-[42rem] -translate-x-1/2 -translate-y-1/3 rounded-full opacity-30 blur-3xl dark:opacity-40"
		style="background: radial-gradient(closest-side, oklch(0.55 0.11 210 / 0.55), transparent);"
	></div>
	<div
		class="absolute left-1/2 top-40 h-[30rem] w-[52rem] -translate-x-1/2 rounded-full opacity-20 blur-3xl dark:opacity-30"
		style="background: radial-gradient(closest-side, oklch(0.62 0.12 80 / 0.45), transparent);"
	></div>
</div>
