---
import BlogPost from '../../layouts/BlogPost.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import BlogBody from '../../components/islands/BlogBody.astro';
import NearbyIslands from '../../components/NearbyIslands.astro';
import PortNavigation from '../../components/PortNavigation.astro';
import { getBlog, listBlogs } from '../../lib/data';
import { islands } from '../../lib/islands';
import { pickPortNeighbours } from '../../lib/port-navigation';
import { pickNearbyIslands } from '../../lib/related-posts';
import { readingTimeMinutes } from '../../lib/reading-time';
import { extractToc } from '../../lib/toc';

export async function getStaticPaths() {
	const posts = await listBlogs();
	return posts.map((node) => ({ params: { slug: node._sys.filename } }));
}

const slug = (Astro.params.slug ?? '').toString();
const blog = await getBlog(slug);
const data = blog.data?.blog;
if (!data) return new Response('Not Found', { status: 404 });

// "Nearby islands" — up to 3 related posts, computed at build time from the
// full collection (shared tags desc, then date desc, never this post).
const allPosts = await listBlogs();
const nearbyPosts = pickNearbyIslands(allPosts, slug);

// "Previous port / Next port" — chronological neighbours (#214), computed at
// build time from the same collection (older = previous, newer = next).
const { previous: previousPort, next: nextPort } = pickPortNeighbours(allPosts, slug);

const layoutProps = {
	title: data.title ?? '',
	description: data.description ?? '',
	pubDate: data.pubDate ? new Date(data.pubDate) : new Date(),
	updatedDate: data.updatedDate ? new Date(data.updatedDate) : undefined,
	heroImage: data.heroImage ?? null,
	// Same estimate BlogBody renders on screen — reused for the print header line.
	readingMinutes: data.body ? readingTimeMinutes(data.body) : null,
	// "Chart of contents" (#213): build-time h2/h3 outline with the same slug
	// ids DropAnchor assigns at runtime. The layout hides it below 3 headings.
	toc: data.body ? extractToc(data.body) : [],
};
---

<BlogPost {...layoutProps}>
	<TinaIsland name="blog" wrapper={islands.blog.wrapper} params={{ slug }} primary>
		<BlogBody data={data} />
	</TinaIsland>
	<PortNavigation previous={previousPort} next={nextPort} />
	<NearbyIslands posts={nearbyPosts} />
</BlogPost>
