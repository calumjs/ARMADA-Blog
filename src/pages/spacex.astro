---
import Base from '../layouts/Base.astro';
import { getConfig } from '../lib/data';
import SpaceXChart from '../components/spacex/SpaceXChart.astro';

const config = (await getConfig()).data?.config ?? null;
---

<Base
	title={`SpaceX Stock · ${config?.seo?.title ?? 'TinaCMS + Astro'}`}
	description="Live SpaceX (SPCX) stock price in US dollars with an interactive historical chart — a ship's-chart for the rocket fleet. Frontend-only, no accounts."
>
	<main class="mx-auto max-w-4xl px-6 py-12">
		<header class="mb-8 flex flex-col gap-3">
			<h1 class="text-4xl font-semibold tracking-tight">SpaceX Stock</h1>
			<p class="max-w-2xl text-muted-foreground">
				A ship's-chart for the rocket fleet. The latest price of SpaceX (ticker
				SPCX, listed on the Nasdaq in June 2026) in US dollars, plus an
				interactive history you can range across — all plotted right here in your
				browser, no accounts and no downloads.
			</p>
			<hr class="rope-divider max-w-2xl" aria-hidden="true" />
		</header>

		<SpaceXChart />
	</main>
</Base>
