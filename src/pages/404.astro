---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';

const ports = [
	{ href: '/blog', label: 'The Blog', hint: 'Logs from the voyage' },
	{ href: '/games', label: 'The Games Deck', hint: 'Idle away a watch' },
	{ href: '/shanties', label: 'The Shanties', hint: 'A song for the haul' },
];
---

<Base
	title="Ye be off the map (404)"
	description="404 — ye be off the map. Dig at the ✕ on the treasure map to be spirited back to home port."
>
	<section class="map-404 relative flex min-h-[75vh] flex-col items-center justify-center overflow-hidden px-6 py-16 text-center">
		<!-- Parchment treasure map. Pure inline SVG + CSS — no image assets. The
		     parchment's palette is self-contained (sepia ink on aged paper), so it
		     stays readable in every theme; the page copy around it uses the theme
		     tokens like the rest of the site. -->
		<div class="map-scene" id="map-scene">
			<svg
				viewBox="0 0 480 320"
				class="map-svg"
				aria-hidden="true"
				focusable="false"
			>
				<defs>
					<radialGradient id="parch" cx="42%" cy="38%" r="85%">
						<stop offset="0%" stop-color="#f0e4c3" />
						<stop offset="70%" stop-color="#e6d5ab" />
						<stop offset="100%" stop-color="#d9c390" />
					</radialGradient>
				</defs>

				<!-- Torn-edged parchment sheet -->
				<path
					class="parchment"
					d="M28 30 q 60 -14 118 -6 q 66 -10 128 2 q 70 -8 128 4 q 30 4 46 18
					   q 12 34 6 66 q 10 40 -2 78 q 8 44 -6 76 q -14 16 -44 20
					   q -62 12 -126 4 q -64 10 -128 -2 q -58 8 -110 -6 q -22 -6 -30 -22
					   q -10 -36 -2 -72 q -10 -42 2 -80 q -8 -38 4 -66 q 6 -10 16 -14 Z"
				/>

				<!-- Aged stains -->
				<ellipse class="stain" cx="120" cy="240" rx="34" ry="18" />
				<ellipse class="stain" cx="392" cy="80" rx="26" ry="14" />
				<ellipse class="stain" cx="250" cy="60" rx="40" ry="12" />

				<!-- Compass rose -->
				<g class="ink compass" transform="translate(84 84)">
					<circle r="24" fill="none" />
					<circle r="3" />
					<path d="M0 -22 L5 0 L0 22 L-5 0 Z" fill="currentColor" stroke="none" opacity="0.85" />
					<path d="M-22 0 L0 5 L22 0 L0 -5 Z" fill="currentColor" stroke="none" opacity="0.5" />
					<text x="0" y="-30" class="map-label" text-anchor="middle">N</text>
				</g>

				<!-- Island coastline -->
				<path
					class="ink coast"
					d="M180 210 q 18 -34 52 -40 q 22 -26 58 -22 q 34 -14 62 6 q 26 8 30 34
					   q 14 22 -4 42 q -8 24 -36 28 q -26 16 -56 8 q -34 8 -60 -8
					   q -30 -4 -42 -24 q -10 -12 -4 -24 Z"
				/>

				<!-- Mountains -->
				<g class="ink">
					<path d="M270 196 l 12 -22 l 12 22" fill="none" />
					<path d="M296 198 l 14 -26 l 14 26" fill="none" />
				</g>

				<!-- Palm tree -->
				<g class="ink">
					<path d="M214 214 q 2 -14 -2 -24" fill="none" />
					<path d="M212 190 q -12 -6 -20 0 M212 190 q 12 -8 20 -2 M212 190 q -2 -10 6 -14" fill="none" />
				</g>

				<!-- Sea squiggles + monster -->
				<g class="ink faint">
					<path d="M60 260 q 8 -6 16 0 t 16 0" fill="none" />
					<path d="M380 250 q 8 -6 16 0 t 16 0" fill="none" />
					<path d="M60 150 q 8 -6 16 0 t 16 0" fill="none" />
				</g>
				<g class="ink monster">
					<path d="M394 176 q 8 -14 20 -8 q 12 6 6 16 M400 172 q 4 -6 10 -2" fill="none" />
					<circle cx="410" cy="171" r="1.6" fill="currentColor" stroke="none" />
					<text x="404" y="196" class="map-label" text-anchor="middle">here be krakens</text>
				</g>

				<!-- Little ship at the route's start -->
				<g class="ink ship" transform="translate(118 196)">
					<path d="M-12 6 q 12 8 24 0 l -3 -6 h -18 Z" fill="currentColor" stroke="none" opacity="0.8" />
					<path d="M0 0 v -16 M0 -16 q 12 4 0 10" fill="none" />
				</g>

				<!-- Dashed route to the dig site -->
				<path
					class="ink route"
					d="M136 202 q 40 20 70 2 q 36 -22 66 -2 q 20 14 34 2"
					fill="none"
				/>
			</svg>

			<!-- Dig site: hole + flying dirt, revealed by the dig animation -->
			<div class="dig-site" aria-hidden="true">
				<span class="hole"></span>
				<span class="dirt dirt-1"></span>
				<span class="dirt dirt-2"></span>
				<span class="dirt dirt-3"></span>
				<span class="dirt dirt-4"></span>
			</div>

			<!-- The marked ✕ — a real link, keyboard accessible. Activating it digs,
			     then sails home. Without JS (or with reduced motion) it is a plain
			     instant link to /. -->
			<a href="/" id="dig-x" class="dig-x" aria-label="Dig at the ✕ and return to the home port">
				<svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true" focusable="false">
					<path d="M8 8 L32 32 M32 8 L8 32" />
				</svg>
			</a>
		</div>

		<p class="mt-4 text-sm font-medium tracking-widest text-primary uppercase">Error 404 · X marks the spot</p>
		<h1 class="mt-3 text-4xl font-semibold tracking-tight text-balance lg:text-5xl">
			Ye be off the map
		</h1>
		<p class="mx-auto mt-4 max-w-xl text-pretty text-muted-foreground">
			This heading leads to no known shore, sailor — the chart ends here and the
			page ye sought lies buried with the rest o' the doubloons. But every good
			map hides a way home: <strong class="font-medium text-foreground">dig at the ✕</strong>
			and ye'll be spirited back to port.
		</p>

		<Button href="/" size="lg" variant="outline" class="mt-8">⚓ Or just sail straight home</Button>

		<nav class="mt-10 w-full max-w-2xl" aria-label="Popular destinations">
			<p class="mb-4 text-xs font-medium tracking-widest text-muted-foreground uppercase">Or chart a course for…</p>
			<ul class="grid gap-3 sm:grid-cols-3">
				{ports.map((port) => (
					<li>
						<a
							href={port.href}
							class="group flex h-full flex-col gap-1 rounded-lg border border-border bg-card px-4 py-3 text-left transition-colors hover:border-primary hover:bg-accent"
						>
							<span class="font-medium text-card-foreground group-hover:text-accent-foreground">{port.label}</span>
							<span class="text-sm text-muted-foreground group-hover:text-accent-foreground/80">{port.hint}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>
	</section>
</Base>

<script>
	// Progressive enhancement: with motion allowed, intercept the ✕ link, play a
	// brief dig animation, then navigate. With prefers-reduced-motion (or no JS)
	// the link navigates instantly like any other anchor.
	const link = document.getElementById('dig-x') as HTMLAnchorElement | null;
	const scene = document.getElementById('map-scene');
	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

	link?.addEventListener('click', (event) => {
		if (!scene || reduced.matches || scene.classList.contains('digging')) return;
		event.preventDefault();
		scene.classList.add('digging');
		window.setTimeout(() => window.location.assign(link.href), 850);
	});
</script>

<style>
	.map-404 {
		background:
			linear-gradient(
				to bottom,
				transparent 0%,
				transparent 55%,
				color-mix(in oklch, var(--primary) 8%, transparent) 100%
			);
	}

	/* --- The map --- */
	.map-scene {
		position: relative;
		width: min(100%, 480px);
		aspect-ratio: 480 / 320;
		/* Lift the parchment off the page in dark and light themes alike. */
		filter: drop-shadow(0 10px 24px color-mix(in oklch, var(--foreground) 22%, transparent));
		animation: sway 7s ease-in-out infinite;
	}

	.map-svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.parchment {
		fill: url(#parch);
		stroke: #a98c58;
		stroke-width: 2.5;
	}

	.stain {
		fill: #b99a63;
		opacity: 0.18;
	}

	.ink {
		color: #5c4630; /* sepia ink — fixed on purpose; contrast is internal to the parchment */
		stroke: currentColor;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.ink.faint {
		opacity: 0.45;
	}

	.coast {
		fill: #dcc998;
		fill-opacity: 0.6;
	}

	.map-label {
		font-family: var(--font-serif);
		font-size: 11px;
		font-style: italic;
		fill: #5c4630;
		stroke: none;
	}

	.route {
		stroke-dasharray: 7 8;
		stroke-width: 2.5;
		animation: march 14s linear infinite;
	}

	/* --- The ✕ (the link) --- */
	.dig-x {
		position: absolute;
		/* Route ends near (306, 204) in the 480×320 viewBox. */
		left: 63.75%;
		top: 63.75%;
		width: clamp(34px, 12%, 48px);
		height: auto;
		aspect-ratio: 1;
		transform: translate(-50%, -50%);
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		cursor: pointer;
		outline: none;
	}

	.dig-x svg {
		width: 72%;
		height: 72%;
	}

	.dig-x path {
		stroke: #8c2f22; /* weathered blood-red ✕, readable on the parchment in all themes */
		stroke-width: 7;
		stroke-linecap: round;
		fill: none;
	}

	.dig-x:hover path {
		stroke: #a33325;
	}

	.dig-x:focus-visible {
		box-shadow: 0 0 0 3px color-mix(in oklch, var(--ring) 65%, transparent);
	}

	.dig-x::after {
		/* Beckoning pulse ring */
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		border: 2px solid #8c2f22;
		opacity: 0;
		animation: beckon 2.4s ease-out infinite;
	}

	/* --- Dig site (hidden until digging) --- */
	.dig-site {
		position: absolute;
		left: 63.75%;
		top: 63.75%;
		width: 0;
		height: 0;
	}

	.hole {
		position: absolute;
		left: -22px;
		top: -9px;
		width: 44px;
		height: 18px;
		border-radius: 50%;
		background: radial-gradient(ellipse at 50% 40%, #3d2c1a 0%, #5c4630 75%);
		transform: scale(0);
	}

	.dirt {
		position: absolute;
		left: -4px;
		top: -4px;
		width: 8px;
		height: 8px;
		border-radius: 50% 50% 50% 20%;
		background: #6f5638;
		opacity: 0;
	}

	/* --- Idle motion --- */
	@keyframes sway {
		0%, 100% { transform: rotate(-0.6deg); }
		50% { transform: rotate(0.6deg); }
	}
	@keyframes march {
		from { stroke-dashoffset: 0; }
		to { stroke-dashoffset: -150; }
	}
	@keyframes beckon {
		0% { opacity: 0.55; transform: scale(0.8); }
		70%, 100% { opacity: 0; transform: scale(1.6); }
	}

	/* --- Dig animation (triggered by JS adding .digging) --- */
	.digging .dig-x {
		animation: x-dig 0.85s ease-in forwards;
	}
	.digging .dig-x::after {
		animation: none;
		opacity: 0;
	}
	.digging .hole {
		animation: hole-open 0.5s ease-out 0.15s forwards;
	}
	.digging .dirt {
		animation: dirt-fly 0.6s ease-out forwards;
	}
	.digging .dirt-1 { animation-delay: 0.1s; --fly-x: -30px; --fly-y: -34px; }
	.digging .dirt-2 { animation-delay: 0.2s; --fly-x: 26px; --fly-y: -40px; }
	.digging .dirt-3 { animation-delay: 0.3s; --fly-x: -16px; --fly-y: -46px; }
	.digging .dirt-4 { animation-delay: 0.38s; --fly-x: 34px; --fly-y: -28px; }
	.digging.map-scene {
		animation: rumble 0.85s linear;
	}

	@keyframes x-dig {
		0% { transform: translate(-50%, -50%) rotate(0deg) scale(1); opacity: 1; }
		30% { transform: translate(-50%, -50%) rotate(-14deg) scale(1.15); opacity: 1; }
		100% { transform: translate(-50%, -30%) rotate(24deg) scale(0.2); opacity: 0; }
	}
	@keyframes hole-open {
		from { transform: scale(0); }
		to { transform: scale(1); }
	}
	@keyframes dirt-fly {
		0% { opacity: 0; transform: translate(0, 0) rotate(0deg); }
		15% { opacity: 1; }
		100% { opacity: 0; transform: translate(var(--fly-x, -20px), var(--fly-y, -40px)) rotate(220deg); }
	}
	@keyframes rumble {
		0%, 100% { transform: translate(0, 0) rotate(0deg); }
		20% { transform: translate(-2px, 1px) rotate(-0.4deg); }
		40% { transform: translate(2px, -1px) rotate(0.4deg); }
		60% { transform: translate(-2px, -1px) rotate(-0.3deg); }
		80% { transform: translate(2px, 1px) rotate(0.3deg); }
	}

	/* Reduced motion: a still chart, and the ✕ is an instant plain link
	   (the script also skips the dig entirely). */
	@media (prefers-reduced-motion: reduce) {
		.map-scene,
		.route,
		.dig-x,
		.dig-x::after,
		.hole,
		.dirt,
		.digging .dig-x,
		.digging.map-scene {
			animation: none;
		}
	}
</style>
