---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KrakenEasterEgg from '../components/KrakenEasterEgg.astro';
import HoistTheColours from '../components/HoistTheColours.astro';
import MessageInABottle from '../components/MessageInABottle.astro';
import SpyglassSearch from '../components/SpyglassSearch.astro';
import CaptainsWheel from '../components/CaptainsWheel.astro';
import OceanHero from '../components/hero/OceanHero.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import { getConfig } from '../lib/data';
import { islands } from '../lib/islands';

interface Props {
	title: string;
	description: string;
	image?: string;
	/** Render the fixed-position WebGL sailing-ship parallax backdrop. */
	oceanHero?: boolean;
}

const { title, description, image, oceanHero = false } = Astro.props;
const config = (await getConfig()).data?.config ?? null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class={oceanHero ? 'has-ocean-hero' : undefined}>
		{oceanHero && <OceanHero />}
		<TinaIsland name="global" wrapper={islands.global.wrapper}>
			<Header config={config} />
		</TinaIsland>
		<slot />
		<TinaIsland name="global-footer" wrapper={islands['global-footer'].wrapper}>
			<Footer config={config} />
		</TinaIsland>
		<KrakenEasterEgg />
		<HoistTheColours />
		<MessageInABottle />
		<SpyglassSearch />
		<CaptainsWheel />
	</body>
</html>

<style is:global>
	/* When the WebGL parallax backdrop is mounted, let it show through:
	   the page background goes transparent and the first hero section drops
	   its opaque fill so the ocean/ship roll behind the landing content. Lower
	   sections keep a translucent parchment so body copy stays readable. */
	body.has-ocean-hero {
		background-color: transparent;
	}
	body.has-ocean-hero .bg-default {
		background-color: transparent;
	}
	/* Sections below the fold get a soft scrim for legibility over the sea. */
	body.has-ocean-hero main :global(section),
	body.has-ocean-hero .bg-default :global(section) {
		position: relative;
	}
</style>
